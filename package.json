{
  "name": "industrialplanner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "assets:normalize": "node scripts/normalize-assets.mjs",
    "assets:refresh": "npm run gen:filled-icons && npm run gen:chrono-icons && npm run assets:normalize",
    "gen:filled-icons": "node scripts/generate-filled-bottle-icons.mjs",
    "gen:chrono-icons": "node scripts/generate-chrono-item-icons.mjs",
    "gen:blueprint-index": "node scripts/generate-blueprint-index.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "opentype.js": "^1.3.4",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
